# انسخ هذا الملف إلى .env واملأ القيم (لا ترفع .env إلى GitHub)

# رابط اتصال PostgreSQL
DATABASE_URL=postgres://USER:PASSWORD@localhost:5432/sened

# فعّل SSL إن كان مزوّد قاعدة البيانات يفرضه (استضافة سحابية) — اجعله 1
PGSSL=0

# منفذ الخادم (خلفه Nginx/Caddy لإضافة HTTPS على 443)
PORT=3050

# حجم مجمّع اتصالات PostgreSQL
PG_POOL_MAX=10
