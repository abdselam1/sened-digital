{
  "name": "sened",
  "productName": "سند",
  "version": "1.0.1",
  "description": "سند — نظام إدارة ومحاسبة ذكي ثلاثي اللغة مدعوم بالذكاء الاصطناعي وبوت تلجرام | Sened — AI-powered trilingual business management & accounting system",
  "main": "main.js",
  "author": "abdselam1",
  "license": "MIT",
  "homepage": "https://github.com/abdselam1/sened-digital",
  "repository": {
    "type": "git",
    "url": "https://github.com/abdselam1/sened-digital.git"
  },
  "keywords": [
    "electron",
    "accounting",
    "management",
    "pos",
    "arabic",
    "ai",
    "telegram-bot",
    "shareholders"
  ],
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "playwright": "^1.61.1"
  },
  "build": {
    "appId": "com.abdselam1.sened",
    "productName": "سند",
    "icon": "assets/icon.ico",
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "assets/**/*",
      "builtin-ai.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico",
      "signAndEditExecutable": false
    },
    "portable": {
      "artifactName": "Sened-Portable-${version}.exe"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "سند للمبيعات",
      "runAfterFinish": false,
      "artifactName": "Sened-Setup-${version}.exe"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon-512.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon-512.png"
    }
  },
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^5.2.1"
  }
}